# ECEEE v4 Production Environment Variables
# Copy this to /opt/eceee/.env on the server and fill in your actual values
# ================================================

# Domain & Email
DOMAIN=eceee.org
EMAIL=admin@eceee.org

# Email Configuration (Postmark)
POSTMARK_API_KEY=your-postmark-server-api-token-here
DEFAULT_FROM_EMAIL=noreply@eceee.org
SERVER_EMAIL=server@eceee.org
ADMIN_EMAIL=admin@eceee.org

# Django Settings
DEBUG=0
DJANGO_SECRET_KEY=your-long-random-secret-key-here-change-this-in-production
ALLOWED_HOSTS=eceee.org,admin.eceee.org,app.eceee.org
CORS_ALLOWED_ORIGINS=https://app.eceee.org
CSRF_TRUSTED_ORIGINS=https://eceee.org,https://admin.eceee.org,https://app.eceee.org

# PostgreSQL Database
POSTGRES_DB=eceee_v4
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password-here
DATABASE_URL=postgresql://postgres:your-secure-postgres-password-here@db:5432/eceee_v4

# Redis
REDIS_URL=redis://redis:6379/0

# Linode Object Storage (get from Linode Cloud Manager -> Object Storage)
LINODE_OBJECT_STORAGE_ACCESS_KEY=your-linode-access-key
LINODE_OBJECT_STORAGE_SECRET_KEY=your-linode-secret-key
LINODE_OBJECT_STORAGE_BUCKET=eceee-v4-media
LINODE_OBJECT_STORAGE_REGION=eu-central-1

# imgproxy Security (generate with: openssl rand -hex 32)
IMGPROXY_KEY=943b421c9eb07c830af81030552c86009268de4e532ba2ee2eab8247c6da0881
IMGPROXY_SALT=520f986b998545b4785e0defbc4f3c1203f22de2374a3d53cb7a7fe9fea309c5
# Internal Docker URL (health checks); public URL for signed links in HTML/API (must match Caddy imgproxy host)
IMGPROXY_URL=http://imgproxy:8080
IMGPROXY_PUBLIC_URL=https://imgproxy.eceee.org

# imgproxy S3 credentials (same Linode keys, used by imgproxy container)
AWS_ACCESS_KEY_ID=your-linode-access-key
AWS_SECRET_ACCESS_KEY=your-linode-secret-key

# AI Provider Keys (optional)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Deployment (set automatically by deploy.sh - you can leave this as-is)
IMAGE_TAG=latest
